<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Lets the app join the Android host's local Wi-Fi hotspot via
	     NEHotspotConfiguration (Hotspot Bridge). Enable the matching "Hotspot
	     Configuration" capability in Xcode → Signing & Capabilities. -->
	<key>com.apple.developer.networking.HotspotConfiguration</key>
	<true/>
</dict>
</plist>
