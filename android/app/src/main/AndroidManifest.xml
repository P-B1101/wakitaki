<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Voice-call audio mode + Bluetooth SCO routing for handsfree headsets. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- Hotspot Bridge: creating a local-only Wi-Fi hotspot for iPhone↔Android.
         CHANGE_WIFI_STATE is required by startLocalOnlyHotspot; on Android 13+
         NEARBY_WIFI_DEVICES replaces the location requirement (neverForLocation
         since we only bring an AP up, never derive location). On API 26–32 the
         hotspot still needs ACCESS_FINE_LOCATION (declared below through 32). -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Bluetooth Classic transport (Android). Legacy permissions are capped
         at API 30 by maxSdkVersion; API 31+ uses the runtime-requested
         BLUETOOTH_CONNECT/BLUETOOTH_SCAN below. neverForLocation is safe
         here since scan results are only used to list nearby device names,
         never to derive physical location. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- Android 6–11 gates ALL Bluetooth scanning (classic discovery and
         BLE) behind location — without these declared, scans silently find
         nothing there. From Android 12 the neverForLocation BLUETOOTH_SCAN
         above replaces them. FINE_LOCATION runs through API 32 (not 30) because
         the Hotspot Bridge's startLocalOnlyHotspot needs it on API 31–32;
         Android 13+ uses NEARBY_WIFI_DEVICES (above) instead. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <!-- BLE hosting (peripheral role) so iPhones can find and join us. -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- System-audio (music) sharing: MediaProjection playback capture must
         run inside a foreground service of type mediaProjection. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Screen-off keep-alive (motorcycle use case): a foreground service holds
         the CPU (WAKE_LOCK) and Wi-Fi awake so audio/UDP keep flowing while the
         screen is off. The session records the mic continuously, so the service
         is typed microphone (FOREGROUND_SERVICE_MICROPHONE, Android 14+).
         REQUEST_IGNORE_BATTERY_OPTIMIZATIONS lets the app prompt the user to
         whitelist it from Doze (essential on MIUI/Xiaomi). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <application
        android:label="تَرک"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"
            />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".audio.SystemAudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />
        <service
            android:name=".keepalive.SessionKeepAliveService"
            android:exported="false"
            android:foregroundServiceType="microphone" />
        <!-- Notification access is the only way a third-party app can pause
             ANOTHER app's media session (see MediaControlHandler) — used so
             stopping music-cast can also stop the source app's local
             playback. We never read notification content; this service only
             needs to exist and be enabled by the user in system settings. -->
        <service
            android:name=".audio.TarkNotificationListenerService"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>
</manifest>